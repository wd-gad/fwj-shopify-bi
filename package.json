{
  "name": "shopify-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "postinstall": "prisma generate",
    "dev": "node --env-file=.env server.js",
    "db:push:manual": "npx prisma db push --accept-data-loss",
    "seed:contest-schedules": "node scripts/seed-contest-schedules.js",
    "products:reclassify": "node scripts/reclassify-products.js",
    "analytics:rebuild": "node scripts/rebuild-analytics.js",
    "startup:init:manual": "npm run db:push:manual && npm run seed:contest-schedules && npm run products:reclassify && npm run analytics:rebuild",
    "contest:import": "node --env-file=.env scripts/import-contest-schedules.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed:dev": "node --env-file=.env prisma/seed.js",
    "shopify:audit": "node --env-file=.env scripts/shopify-audit.js",
    "shopify:config": "node --env-file=.env scripts/shopify-config-cli.js",
    "shopify:setup-google-chat-webhook": "node --env-file=.env scripts/setup-google-chat-order-webhook.mjs",
    "shopify:monthly-points": "node --env-file=.env scripts/shopify-monthly-points.js",
    "shopify:preflight": "node --env-file=.env scripts/shopify-preflight.js",
    "shopify:reward-report": "node --env-file=.env scripts/shopify-reward-report.js",
    "shopify:sync": "node --env-file=.env scripts/shopify-sync.js",
    "shopify:rebuild": "node --env-file=.env scripts/rebuild-analytics.js",
    "notify:weekend-rentals": "node --env-file=.env scripts/notify-weekend-rentals.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
